{
  "name": "track3",
  "version": "0.0.1",
  "description": "share your music the way you want it",
  "homepage": "https://github.com/egnrse/track3",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/egnrse/track3.git"
  },
  "license": "GPL-3.0-or-later",
  "author": "Elia Nitsche",
  "scripts": {
    "prestart": "pnpm run build",
    "start": "node backend/dist/server.js",
    "dev": "tsx --watch backend/server.ts",
    "devF": "tsc --watch -p ./public",
    "build:front": "tsc -p ./public",
    "build:back": "tsc -p ./backend",
    "build": "pnpm run build:front && pnpm run build:back",
    "test:front": "tsc --noEmit -p ./public/",
    "test:back": "tsc --noEmit -p ./backend/",
    "test": "pnpm run test:front && pnpm run test:back"
  },
  "type": "module",
  "dependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.2",
    "express": "^5.2.1",
    "typescript": "^6.0.2"
  },
  "devDependencies": {
    "tsx": "^4.21.0"
  }
}
